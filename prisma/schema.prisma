// Cue - Prisma schema
// Multi-client social media scheduler (LinkedIn + Instagram MVP)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Workspaces (tenants) - every user + client belongs to exactly one
// ---------------------------------------------------------------------------

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users   User[]
  clients Client[]
}

// ---------------------------------------------------------------------------
// Team / auth
// ---------------------------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(MANAGER)
  createdAt DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String

  posts    Post[]
  comments Comment[]
}

enum Role {
  ADMIN
  MANAGER
}

// ---------------------------------------------------------------------------
// Clients (workspaces) + connected social accounts
// ---------------------------------------------------------------------------

model Client {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  color     String?  @default("#2A6FF2")
  createdAt DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId String

  accounts SocialAccount[]
  posts    Post[]
}

model SocialAccount {
  id           String    @id @default(cuid())
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String
  platform     Platform
  displayName  String
  externalId   String // LinkedIn org URN / IG business account id
  accessToken  String // encrypted at rest
  refreshToken String? // encrypted at rest
  tokenExpires DateTime?
  scopes       String?
  createdAt    DateTime  @default(now())

  targets PostTarget[]

  @@unique([clientId, platform, externalId])
}

enum Platform {
  LINKEDIN
  INSTAGRAM
  YOUTUBE
}

// ---------------------------------------------------------------------------
// Posts + per-account publish targets + media
// ---------------------------------------------------------------------------

model Post {
  id             String         @id @default(cuid())
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId       String
  author         User           @relation(fields: [authorId], references: [id])
  authorId       String
  body           String
  title          String? // YouTube video title (unused by LinkedIn/Instagram)
  youtubePrivacy String? // YouTube visibility: public | unlisted | private (null for non-YT)
  scheduledAt    DateTime?
  status         PostStatus     @default(DRAFT)
  approval       ApprovalStatus @default(APPROVED)
  // LinkedIn-only content types (null = a normal text/media post):
  link           Json? // { url, title, description } - link-preview post
  poll           Json? // { question, options: string[], duration } - poll post
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  media    MediaAsset[]
  targets  PostTarget[]
  comments Comment[]
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  PARTIAL
  FAILED
}

// Client/internal approval state. Defaults to APPROVED so posts publish
// unless someone explicitly puts them into review.
enum ApprovalStatus {
  PENDING
  APPROVED
  CHANGES_REQUESTED
}

model PostTarget {
  id             String        @id @default(cuid())
  post           Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId         String
  account        SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId      String
  platform       Platform
  status         TargetStatus  @default(SCHEDULED)
  bodyOverride   String?
  publishedAt    DateTime?
  externalPostId String?
  permalink      String?
  error          String?
  attempts       Int           @default(0)
}

enum TargetStatus {
  SCHEDULED
  PROCESSING
  PUBLISHED
  FAILED
}

model MediaAsset {
  id         String    @id @default(cuid())
  post       Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId     String
  type       MediaType
  url        String // public Cloudflare R2 URL
  storageKey String // R2 object key (deleted on cleanup)
  title      String? // display filename, used for DOCUMENT posts
  createdAt  DateTime  @default(now())
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

model Comment {
  id        String   @id @default(cuid())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  author    User     @relation(fields: [authorId], references: [id])
  authorId  String
  body      String
  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Permanent lightweight history - survives the 7-day purge (no FK to Post)
// ---------------------------------------------------------------------------

model PostHistory {
  id             String    @id @default(cuid())
  // Denormalized tenant id (PostHistory has no FK to Client - it outlives it).
  workspaceId    String
  clientId       String
  clientName     String
  platform       Platform
  externalPostId String
  permalink      String?
  publishedAt    DateTime
  // compact metrics only (optional, for future analytics)
  likes          Int?
  comments       Int?
  reach          Int?
  clicks         Int?
  lastSyncedAt   DateTime?
}
